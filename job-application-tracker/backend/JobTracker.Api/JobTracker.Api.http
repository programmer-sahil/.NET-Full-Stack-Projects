@JobTracker.Api_HostAddress = http://localhost:5000
@Token = paste-jwt-token-here

POST {{JobTracker.Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Demo User",
  "email": "demo@example.com",
  "password": "Password123"
}

###

POST {{JobTracker.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "demo@example.com",
  "password": "Password123"
}

###

GET {{JobTracker.Api_HostAddress}}/api/dashboard/stats
Authorization: Bearer {{Token}}
Accept: application/json

###

GET {{JobTracker.Api_HostAddress}}/api/applications
Authorization: Bearer {{Token}}
Accept: application/json
